<Window
    x:Class="AddInManager.Wpf.LogViewerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:props="clr-namespace:AddInManager.Properties"
    Title="{x:Static props:Resources.LogViewerTitle}"
    Width="980"
    Height="560"
    Background="{DynamicResource BackgroundBrush}"
    WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/AddInManager;component/Wpf/Styles/ModernStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border
        Margin="12"
        Padding="12"
        Style="{StaticResource WindowContainer}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                Margin="0,0,0,8"
                Orientation="Horizontal">
                <CheckBox
                    x:Name="chkInfo"
                    Margin="0,0,12,0"
                    Checked="Filter_Changed"
                    Content="{x:Static props:Resources.LogLevelInfo}"
                    IsChecked="True"
                    Unchecked="Filter_Changed" />
                <CheckBox
                    x:Name="chkWarning"
                    Margin="0,0,12,0"
                    Checked="Filter_Changed"
                    Content="{x:Static props:Resources.LogLevelWarning}"
                    IsChecked="True"
                    Unchecked="Filter_Changed" />
                <CheckBox
                    x:Name="chkError"
                    Margin="0,0,20,0"
                    Checked="Filter_Changed"
                    Content="{x:Static props:Resources.LogLevelError}"
                    IsChecked="True"
                    Unchecked="Filter_Changed" />
                <CheckBox
                    x:Name="chkDebugLogger"
                    Margin="0,0,12,0"
                    Checked="Filter_Changed"
                    Content="{x:Static props:Resources.LogSourceDebugLogger}"
                    IsChecked="True"
                    Unchecked="Filter_Changed" />
                <CheckBox
                    x:Name="chkSystemDiagnostics"
                    Margin="0,0,20,0"
                    Checked="Filter_Changed"
                    Content="{x:Static props:Resources.LogSourceSystemDiagnostics}"
                    IsChecked="True"
                    Unchecked="Filter_Changed" />
                <Button
                    x:Name="btnClear"
                    Click="BtnClear_Click"
                    Content="{x:Static props:Resources.BtnClearLog}"
                    Style="{StaticResource ActionButton}" />
                <Button
                    x:Name="btnExport"
                    Margin="8,0,0,0"
                    Click="BtnExport_Click"
                    Content="{x:Static props:Resources.BtnExport}"
                    Style="{StaticResource ActionButton}" />
                <CheckBox
                    x:Name="chkAutoScroll"
                    Margin="16,0,0,0"
                    Content="{x:Static props:Resources.ChkAutoScroll}"
                    IsChecked="True" />
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource ContentContainer}">
                <ListView
                    x:Name="logListView"
                    BorderThickness="0"
                    FontFamily="Consolas"
                    SelectionMode="Single"
                    Style="{StaticResource ModernListView}"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListView.View>
                        <GridView ColumnHeaderContainerStyle="{StaticResource ModernGridViewColumnHeader}">
                            <GridViewColumn
                                Width="90"
                                DisplayMemberBinding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}"
                                Header="{x:Static props:Resources.ColTime}" />
                            <GridViewColumn
                                Width="70"
                                DisplayMemberBinding="{Binding Level}"
                                Header="{x:Static props:Resources.ColLevel}" />
                            <GridViewColumn
                                Width="150"
                                DisplayMemberBinding="{Binding Source}"
                                Header="{x:Static props:Resources.ColSource}" />
                            <GridViewColumn
                                Width="600"
                                DisplayMemberBinding="{Binding Message}"
                                Header="{x:Static props:Resources.ColMessage}" />
                        </GridView>
                    </ListView.View>
                    <ListView.ItemContainerStyle>
                        <Style BasedOn="{StaticResource ModernListViewItem}" TargetType="ListViewItem">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                    <Setter Property="Foreground" Value="#9A6B00" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                    <Setter Property="Foreground" Value="#A4262C" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Border>

            <TextBlock
                x:Name="statusText"
                Grid.Row="2"
                Style="{StaticResource ModernStatusText}"
                Text="{x:Static props:Resources.StatusReady}" />
        </Grid>
    </Border>
</Window>
