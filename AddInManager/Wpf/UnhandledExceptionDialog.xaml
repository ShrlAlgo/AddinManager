<Window
    x:Class="AddInManager.Wpf.UnhandledExceptionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:props="clr-namespace:AddInManager.Properties"
    Title="{x:Static props:Resources.ExceptionTitle}"
    Width="700"
    Height="480"
    Background="{DynamicResource BackgroundBrush}"
    ResizeMode="CanResizeWithGrip"
    WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ResourceDictionary Source="Styles/ModernStyles.xaml" />
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,10"
            Orientation="Horizontal">
            <TextBlock
                Margin="0,0,10,0"
                VerticalAlignment="Center"
                FontSize="24"
                Foreground="#FFFF6B6B"
                Text="⚠" />
            <StackPanel>
                <TextBlock
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="#FFFF6B6B"
                    Text="{x:Static props:Resources.ExceptionHeader}" />
                <TextBlock
                    x:Name="exceptionTypeText"
                    FontSize="11"
                    Text="" />
            </StackPanel>
        </StackPanel>

        <!--  Message  -->
        <Border
            Grid.Row="1"
            Margin="0,0,0,8"
            Padding="8"
            BorderThickness="1"
            CornerRadius="3">
            <TextBlock
                x:Name="messageText"
                FontSize="12"
                Text=""
                TextWrapping="Wrap" />
        </Border>

        <!--  Stack trace  -->
        <Border
            Grid.Row="2"
            BorderThickness="1"
            CornerRadius="3">
            <DockPanel>
                <TextBlock
                    Margin="8,6,8,4"
                    DockPanel.Dock="Top"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Text="{x:Static props:Resources.ExceptionStackTrace}" />
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <TextBox
                        x:Name="stackTraceText"
                        Margin="8,0,8,8"
                        BorderThickness="0"
                        FontFamily="Consolas"
                        FontSize="11"
                        IsReadOnly="True"
                        Text=""
                        TextWrapping="NoWrap" />
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!--  Buttons  -->
        <UniformGrid
            Grid.Row="3"
            Margin="0,10,0,0"
            HorizontalAlignment="Right"
            Rows="1">
            <Button
                x:Name="btnCopy"
                Margin="0,0,8,0"
                Click="BtnCopy_Click"
                Content="{x:Static props:Resources.BtnCopyDetails}"
                Cursor="Hand" />
            <Button
                x:Name="btnClose"
                Click="BtnClose_Click"
                Content="{x:Static props:Resources.BtnClose}"
                Cursor="Hand"
                IsDefault="True" />
        </UniformGrid>
    </Grid>
</Window>
