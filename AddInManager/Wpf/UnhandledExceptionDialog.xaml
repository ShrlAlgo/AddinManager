<Window
    x:Class="AddInManager.Wpf.UnhandledExceptionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="未处理的异常"
    Width="700"
    Height="480"
    Background="#FF1E1E1E"
    ResizeMode="CanResizeWithGrip"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,10"
            Orientation="Horizontal">
            <TextBlock
                Margin="0,0,10,0"
                VerticalAlignment="Center"
                FontSize="24"
                Foreground="#FFFF6B6B"
                Text="⚠" />
            <StackPanel>
                <TextBlock
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="#FFFF6B6B"
                    Text="应用程序遇到未处理的异常" />
                <TextBlock
                    x:Name="exceptionTypeText"
                    FontSize="11"
                    Foreground="#FF888888"
                    Text="" />
            </StackPanel>
        </StackPanel>

        <!--  Message  -->
        <Border
            Grid.Row="1"
            Margin="0,0,0,8"
            Padding="8"
            Background="#FF2D2D30"
            BorderBrush="#FF555555"
            BorderThickness="1"
            CornerRadius="3">
            <TextBlock
                x:Name="messageText"
                FontSize="12"
                Foreground="#FFDCDCDC"
                Text=""
                TextWrapping="Wrap" />
        </Border>

        <!--  Stack trace  -->
        <Border
            Grid.Row="2"
            Background="#FF252526"
            BorderBrush="#FF3C3C3C"
            BorderThickness="1"
            CornerRadius="3">
            <DockPanel>
                <TextBlock
                    Margin="8,6,8,4"
                    DockPanel.Dock="Top"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Foreground="#FF9CDCFE"
                    Text="堆栈跟踪" />
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <TextBox
                        x:Name="stackTraceText"
                        Margin="8,0,8,8"
                        Background="Transparent"
                        BorderThickness="0"
                        FontFamily="Consolas"
                        FontSize="11"
                        Foreground="#FFDCDCDC"
                        IsReadOnly="True"
                        Text=""
                        TextWrapping="NoWrap" />
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!--  Buttons  -->
        <StackPanel
            Grid.Row="3"
            Margin="0,10,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                x:Name="btnCopy"
                Width="100"
                Height="28"
                Margin="0,0,8,0"
                Background="#FF3C3C3C"
                BorderBrush="#FF555555"
                Click="BtnCopy_Click"
                Content="复制详情"
                Cursor="Hand"
                Foreground="#FFDCDCDC" />
            <Button
                x:Name="btnClose"
                Width="80"
                Height="28"
                Background="#FF3C3C3C"
                BorderBrush="#FF555555"
                Click="BtnClose_Click"
                Content="关闭"
                Cursor="Hand"
                Foreground="#FFDCDCDC"
                IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
