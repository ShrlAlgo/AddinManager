<Window
    x:Class="AddInManager.Wpf.UnhandledExceptionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="未处理的异常"
    Width="700"
    Height="480"
    WindowStartupLocation="CenterScreen"
    Background="#FF1E1E1E"
    ResizeMode="CanResizeWithGrip">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="⚠" Foreground="#FFFF6B6B" FontSize="24"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <StackPanel>
                <TextBlock Text="应用程序遇到未处理的异常"
                           Foreground="#FFFF6B6B" FontSize="14" FontWeight="Bold"/>
                <TextBlock x:Name="exceptionTypeText"
                           Foreground="#FF888888" FontSize="11"
                           Text=""/>
            </StackPanel>
        </StackPanel>

        <!-- Message -->
        <Border Grid.Row="1"
                Background="#FF2D2D30"
                BorderBrush="#FF555555"
                BorderThickness="1"
                CornerRadius="3"
                Padding="8"
                Margin="0,0,0,8">
            <TextBlock x:Name="messageText"
                       Foreground="#FFDCDCDC"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Text=""/>
        </Border>

        <!-- Stack trace -->
        <Border Grid.Row="2"
                Background="#FF252526"
                BorderBrush="#FF3C3C3C"
                BorderThickness="1"
                CornerRadius="3">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="堆栈跟踪"
                           Foreground="#FF9CDCFE"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="8,6,8,4"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <TextBox x:Name="stackTraceText"
                             Background="Transparent"
                             Foreground="#FFDCDCDC"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="11"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             Margin="8,0,8,8"
                             Text=""/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnCopy" Content="复制详情"
                    Width="100" Height="28"
                    Margin="0,0,8,0"
                    Background="#FF3C3C3C"
                    Foreground="#FFDCDCDC"
                    BorderBrush="#FF555555"
                    Cursor="Hand"
                    Click="BtnCopy_Click"/>
            <Button x:Name="btnClose" Content="关闭"
                    Width="80" Height="28"
                    Background="#FF3C3C3C"
                    Foreground="#FFDCDCDC"
                    BorderBrush="#FF555555"
                    Cursor="Hand"
                    IsDefault="True"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
