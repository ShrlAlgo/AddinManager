<Window
    x:Class="AddInManager.Wpf.DependencyGraphWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="插件依赖分析"
    Width="900"
    Height="580"
    WindowStartupLocation="CenterScreen"
    Background="#FF1E1E1E">

    <Window.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF3C3C3C"/>
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF505050"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <Button x:Name="btnRefresh" Content="刷新分析" Style="{StaticResource ToolbarButtonStyle}"
                    Click="BtnRefresh_Click"/>
            <TextBlock Foreground="#FF888888" VerticalAlignment="Center"
                       Margin="16,0,0,0" FontSize="11"
                       Text="选择左侧插件查看其引用的程序集列表。"/>
        </StackPanel>

        <!-- Main content area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Addin list (left) -->
            <Border Grid.Column="0"
                    Background="#FF252526"
                    BorderBrush="#FF3C3C3C"
                    BorderThickness="1"
                    CornerRadius="3">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="已加载的插件"
                               Foreground="#FF9CDCFE"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="8,6,8,4"/>
                    <ListView x:Name="addinListView"
                              Background="Transparent"
                              BorderThickness="0"
                              Foreground="#FFDCDCDC"
                              FontSize="12"
                              SelectionChanged="AddinListView_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="typeTag"
                                               Text="{Binding AddinTypeLabel}"
                                               FontSize="10"
                                               Foreground="#FF888888"
                                               Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="6,4"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center"
                          Background="#FF3C3C3C" ResizeBehavior="PreviousAndNext"/>

            <!-- Dependency detail (right) -->
            <Border Grid.Column="2"
                    Background="#FF252526"
                    BorderBrush="#FF3C3C3C"
                    BorderThickness="1"
                    CornerRadius="3">
                <DockPanel Margin="8">
                    <TextBlock x:Name="detailHeader"
                               DockPanel.Dock="Top"
                               Text="引用的程序集"
                               Foreground="#FF9CDCFE"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="filePathText"
                               DockPanel.Dock="Top"
                               Foreground="#FF888888"
                               FontSize="10"
                               FontFamily="Consolas"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6"
                               Text=""/>
                    <ListView x:Name="depsListView"
                              Background="Transparent"
                              BorderThickness="0"
                              Foreground="#FFDCDCDC"
                              FontFamily="Consolas"
                              FontSize="12">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="4,2"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <TextBlock x:Name="statusText" Grid.Row="2"
                   Foreground="#FF888888" FontSize="11"
                   Margin="0,4,0,0"
                   Text="就绪"/>
    </Grid>
</Window>
